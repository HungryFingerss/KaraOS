# =============================================================================
# KaraOS environment variables
#
# This is a TEMPLATE file with empty values. Real keys live in `.env`,
# which is gitignored.
#
# After cloning the repo on a new laptop:
#   1. cp .env.example .env
#   2. Open .env in a text editor
#   3. Fill in each key from your password manager (or wherever you backed
#      them up to before losing the previous laptop).
#   4. Save. The pipeline will pick up the .env automatically on next run.
# =============================================================================

# --- LLM and search provider keys ---

# Together.ai — primary LLM provider for the brain (chat completions, embeddings)
TOGETHER_API_KEY=

# Tavily — web search tool used by the `search_web` brain tool
TAVILY_API_KEY=

# HuggingFace — required for downloading pyannote diarization models (gated repo)
HF_TOKEN=

# Optional: Groq — set if you want to use as an alternate provider.
# Pipeline does not require this to run.
# (GEMINI_API_KEY + SARVAM_API_KEY removed in P0.S6 D2.b — orphan credentials
# rotated at provider and pruned from .env.example. If a future integration
# revives Gemini or Sarvam, add the entry back here. The matching
# _SECRET_NAMES block in tests/test_secrets_invariants.py stays — entry
# transitions from "rotated-but-kept-for-blocking" to "active production
# secret" so D3.a's print/log scan continues to protect the variable name.)
GROQ_API_KEY=

# --- Local environment overrides ---

# Camera index for OpenCV (typically 0 for built-in webcam, 1+ for USB)
CAMERA_INDEX=0

# Ollama model — used as fallback brain when Together.ai is unavailable.
# Must be pulled locally: `ollama pull qwen2.5:7b`
OLLAMA_MODEL=qwen2.5:7b

# Python interpreter path — used by some scripts to invoke pipeline.py.
# Set to the venv python on this machine. Example values:
#   Windows: C:\Users\<you>\karaos\venv\Scripts\python.exe
#   Linux/Mac: /home/<you>/karaos/venv/bin/python
PYTHON_PATH=
