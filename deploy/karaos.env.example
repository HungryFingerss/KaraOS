# karaos cognitive runtime — environment variables
#
# Copy this file to /etc/karaos/karaos.env (chmod 0600, owned by karaos user)
# OR set as supervisord environment via shell export
#
# All keys except DASHBOARD_BIND / DASHBOARD_BIND_ALLOW_ANY correspond to os.getenv(...) calls in core/config.py; the DASHBOARD_BIND* keys are consumed by karaos-dashboard/scripts/launch.js (default 127.0.0.1 lives there as DEFAULT_BIND).
# Programmatic enforcement at tests/test_p0_r4_process_supervisor.py::A8.
#
# === Required ===
TOGETHER_API_KEY=
#
# === Optional ===
#
# pyannote diarization-3.1 — accept HuggingFace license first:
HF_TOKEN=
#
# Alternate LLM provider (used if configured; falls back to TOGETHER_API_KEY otherwise):
GROQ_API_KEY=
#
# Web search tool — load-bearing for search_web functionality (Session 30 lineage).
# Without this, the `search_web` LLM tool returns auth-failure at runtime:
TAVILY_API_KEY=
#
# === Optional overrides (defaults in core/config.py, except DASHBOARD_BIND* — see karaos-dashboard/scripts/launch.js) ===
# DASHBOARD_BIND=127.0.0.1
# DASHBOARD_BIND_ALLOW_ANY=
#
# KaraOS instance mode (SB.1 D4) — deployment-intent declaration. Default "base"
# (cloneable/publishable; personal data untracked + gitignored). Jagan's personal
# instance sets "personal" so the boot log (+ future SB.5 write-path enforcement)
# reflect that the personal DBs persist on disk + via DAILY_BACKUP snapshots:
# KARAOS_INSTANCE_MODE=base
