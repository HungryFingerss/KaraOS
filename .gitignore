# =============================================================================
# Environment / secrets — NEVER commit real .env to git
# (.env.example IS committed — empty template for new-laptop restore)
# =============================================================================
.env
*.env
.env.local
.env.*.local
!.env.example

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.pyc
*.pyo
venv/
.venv/
.pytest_cache/

# =============================================================================
# Models (large files) — handled via git-lfs, see .gitattributes
# All model files in models/ are tracked through LFS rather than ignored,
# so they ride alongside the code on clone. The patterns below stay as a
# safety net in case a non-LFS-tracked model ends up in here.
#
# Root-level model weights at repo root (yolo11s.pt etc.) — auto-downloaded
# by ultralytics on first run, no need to commit.
# =============================================================================
*.pt
yolo11s.pt

# =============================================================================
# Bootstrap caches (regenerable from seed JSONL — not load-bearing)
# =============================================================================
bootstrap/classifier/cache/

# =============================================================================
# SpeechBrain ECAPA-TDNN pretrained model cache.
# These are SYMLINKS pointing into the local HuggingFace cache
# (~/.cache/huggingface/hub/...). Useless on a different machine.
# SpeechBrain auto-downloads to a fresh cache on first import.
# =============================================================================
pretrained_models/

# =============================================================================
# Classifier DB — committed for backup. Transient SQLite WAL/SHM files NOT
# committed (they're write-ahead logs, regenerated by SQLite on demand).
# Daily snapshots also gitignored — they're regenerated automatically.
# =============================================================================
data/classifier_scenarios.db-shm
data/classifier_scenarios.db-wal
data/classifier_snapshots/
faces/snapshots/

# =============================================================================
# Faces data — committed for backup so "Jagan stays Jagan" after restore.
# Transient SQLite WAL/SHM files NOT committed.
# =============================================================================
faces/*.db-shm
faces/*.db-wal
faces/*.broken

# =============================================================================
# Node / dashboard build artifacts
# =============================================================================
node_modules/
.next/
dog-ai-dashboard/.next/
dog-ai-dashboard/node_modules/

# =============================================================================
# Live session logs — REAL personal data including conversations with people
# who consented to AI recording but not to those recordings being on a remote
# server. NEVER commit, even to a private repo.
# =============================================================================
terminal_output*.md

# =============================================================================
# Claude Code working state
# Keep .claude/settings.json + .claude/CLAUDE.md if any (project config).
# Ignore per-session memory, custom agents, machine-specific overrides,
# and the rolling session log.
# =============================================================================
.claude/projects/
.claude/agents/
.claude/local/
.claude/settings.local.json
.claude/hooks/*.log

# =============================================================================
# Root-level .md files — most are working drafts or superseded specs.
# Only the canonical docs are committed; everything else stays local.
#
# Committed (explicitly allowed below):
#   - CLAUDE.md                      ← development memory, every session logged
#   - README.md                      ← project intro
#   - everything_about_system.md     ← canonical system documentation
#   - KARAOS_COMPLETE_GUIDE.md       ← layman-friendly system guide
#   - KARAOS_KNOWLEDGE.md            ← technical knowledge dump
#   - SETUP.md                       ← restore instructions for new laptop
#
# Ignored (everything else at root):
#   - INTENT_AGENT_PLAN.md, MEMORY_ARCHITECTURE.md, PHASE5_SPEC.md,
#     RECONCILER_DESIGN.md, VISION_ROADMAP*.md, VOICE_*_SPEC.md,
#     CLASSIFIER_GRAPH_SPEC_*.md, STRANGER_DETECTION_RESTORE_SPEC.md,
#     TEST_ISOLATION_FIX_SPEC.md, DRAFT_RECONCILER_MAPPING.md,
#     read_this_before_working.md, info.md, add_this_to_git.md,
#     issues_to_work.md, etc.
#
# The leading `/` anchors the rule to the repo root only — subdirectory READMEs
# (e.g. bootstrap/classifier/README.md) stay tracked normally.
# =============================================================================
/*.md
!/everything_about_system.md
!/KARAOS_COMPLETE_GUIDE.md
!/KARAOS_KNOWLEDGE.md
!/CLAUDE.md
!/README.md
!/SETUP.md

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
